generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
}

enum InquirySource {
  CONTACT
  QUOTE
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  CLOSED
  SPAM
}

enum SubscriberStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
}

model User {
  id                String         @id @default(uuid())
  email             String         @unique
  fullName          String
  passwordHash      String
  role              UserRole       @default(STAFF)
  isActive          Boolean        @default(true)
  lastLoginAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  refreshTokens     RefreshToken[]
  inquiryNotes      InquiryNote[]  @relation("InquiryNoteAuthor")
  assignedInquiries Inquiry[]      @relation("InquiryAssignee")
  auditLogs         AuditLog[]     @relation("AuditLogActor")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Inquiry {
  id           String        @id @default(uuid())
  source       InquirySource
  fullName     String
  email        String
  phone        String?
  service      String?
  message      String
  status       InquiryStatus @default(NEW)
  submittedAt  DateTime      @default(now())
  assignedToId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  notes        InquiryNote[]
  assignedTo   User?         @relation("InquiryAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([source])
  @@index([submittedAt])
  @@index([email])
  @@index([assignedToId])
}

model InquiryNote {
  id        String   @id @default(uuid())
  inquiryId String
  authorId  String
  note      String
  createdAt DateTime @default(now())
  inquiry   Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  author    User     @relation("InquiryNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([inquiryId])
  @@index([authorId])
}

model NewsletterSubscriber {
  id               String           @id @default(uuid())
  email            String           @unique
  status           SubscriberStatus @default(ACTIVE)
  unsubscribeToken String           @unique
  sourcePage       String?
  subscribedAt     DateTime         @default(now())
  unsubscribedAt   DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([status])
  @@index([subscribedAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  actor      User?    @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
