NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
TRUST_PROXY=false

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mmk_accountants?schema=public

JWT_ACCESS_SECRET=change_this_to_a_long_random_secret
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

CORS_ORIGINS=http://localhost:3000,http://localhost:4173

RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=200
AUTH_RATE_LIMIT_MAX_REQUESTS=20
FORM_RATE_LIMIT_MAX_REQUESTS=20

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@mmkaccountants.com
NOTIFICATION_TO=mail@mmkaccountants.com

SEED_ADMIN_EMAIL=admin@mmkaccountants.local
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=MMK Admin
